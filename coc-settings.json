{
  "coc.preferences.formatOnSaveFiletypes": [
    "nim",
    "python",
    "c",
    "cpp",
    "sh",
    "markdown",
    "rust"
  ],
  "languageserver": {
    "nim": {
      "command": "nimlsp",
      "filetypes": ["nim", "nims"],
      "rootPatterns": ["*.nimble", ".git"]
    },
    "clangd": {
      "command": "clangd",
      "filetypes": ["c", "cpp", "objc", "objcpp"],
      "rootPatterns": [".clangd", "compile_commands.json", ".git"]
    },
    "rust": {
      "command": "rust-analyzer",
      "filetypes": ["rust"],
      "rootPatterns": ["Cargo.toml"]
    },
    "bash": {
      "command": "bash-language-server",
      "args": ["start"],
      "filetypes": ["sh"],
      "ignoredRootPaths": ["~"]
    },
    "python": {
      "command": "pylsp",
      "filetypes": ["python"],
      "rootPatterns": ["pyproject.toml", "setup.py", ".git"]
    },
    "markdown": {
      "command": "marksman",
      "filetypes": ["markdown", "markdown.mdx"],
      "rootPatterns": [".git", ".marksman.toml"]
    },
    "ruby": {
      "command": "solargraph",
      "args": ["stdio"],
      "filetypes": ["ruby"],
      "initializationOptions": {
        "diagnostics": true,
        "completion": true,
        "hover": true
      }
    }
  },
}
