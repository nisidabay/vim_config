{
  "languageserver": {
    "sh": {
      "formatting": {
        "provider": "shfmt",
        "command": "/usr/sbin/shfmt"
        "args": ["-i", "2", "-ci", "-bn", "-sr"]
      }
    },
    "golang": {
      "command": "gopls",
      "filetypes": ["go"],
      "rootPatterns": ["go.mod"],
      "settings": {
        "gopls": {
          "completeUnimported": true
        }
      }
    },
    "kotlin": {
      "command": "/Users/nisidabay/.vim/lsp/server/bin/kotlin-language-server",
      "args": ["start"],
      "filetypes": ["kotlin"]
    },
    "ruby": {
      "command": "solargraph",
      "args": ["stdio"],
      "filetypes": ["ruby"],
      "initializationOptions": {
        "diagnostics": true,
        "completion": true,
        "hover": true,
        "formatting": true
      },
      "settings": {
        "solargraph": {
          "formatting": true
        }
      }
    },
    "clangd": {
      "command": "clangd",
      "args": [
        "--background-index",
        "--clang-tidy",
        "--header-insertion=iwyu",
        "--completion-style=detailed",
        "--function-arg-placeholders"
      ],
      "filetypes": ["c", "cpp", "objc", "objcpp"]
    }
  },

  // Enable format on save for all languages
  "coc.preferences.formatOnSaveFiletypes": ["ruby", "go", "cpp", "c", "kotlin,sh"],

  // Ruby formatting with Rufo
  "ruby.format.enable": true,
  "ruby.format.provider": "rufo",
  "rufo": {
    "enable": true,
    "executablePath": "rufo",
    "args": []
  },

  // Go formatting with goimports
  "go.formatTool": "goimports",
  "go.formatOnSave": true,

  // C/C++ formatting with clang-format
  "clangd.arguments": ["--clang-tidy"],
  "coc.source.clangd.format.enable": true,

  // Kotlin formatting with ktlint
  "kotlin.formatter": "ktlint",
  "ktlint": {
    "enable": true,
    "executablePath": "ktlint",
    "args": ["-F"]
  }
}
