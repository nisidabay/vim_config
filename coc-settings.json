{
  "coc.preferences.formatOnSaveFiletypes": [
    "nim",
    "python",
    "c",
    "cpp",
    "sh",
    "markdown"
  ],
  "python.formatting.provider": "black",
  "sh.formatter": "shfmt",
  "languageserver": {
    "nim": {
      "command": "nimlangserver",
      "filetypes": [
        "nim",
        "nims"
      ],
      "rootPatterns": [
        "*.nimble",
        ".git"
      ]
    }
  }
}
