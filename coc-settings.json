{
  "coc.preferences.formatOnSaveFiletypes": [
    "nim",
    "python",
    "c",
    "cpp",
    "sh",
    "markdown",
    "rust"
  ],
  "python.formatting.provider": "black",
  "sh.formatter": "shfmt",
  "languageserver": {
    "nim": {
      "command": "nimlsp",
      "filetypes": [
        "nim",
        "nims"
      ],
      "rootPatterns": [
        "*.nimble",
        ".git"
      ]
    },
    "ccls": {
      "command": "clangd",
      "filetypes": [
        "c",
        "cpp",
        "objc",
        "objcpp"
      ],
      "rootPatterns": [
        ".ccls",
        "compile_commands.json",
        ".git"
      ]
    },
    "rust": {
      "command": "rust-analyzer",
      "filetypes": [
        "rust"
      ],
      "rootPatterns": [
        "Cargo.toml"
      ]
    },
    "bash": {
      "command": "bash-language-server",
      "args": [
        "start"
      ],
      "filetypes": [
        "sh"
      ],
      "ignoredRootPaths": [
        "~"
      ]
    }
  }
}
