{
  "languageserver": {
    "bash": {
      "command": "bash-language-server",
      "args": ["start"],
      "filetypes": ["sh"],
      "ignoredRootPaths": ["~"]
    },
    "golang": {
      "command": "gopls",
      "filetypes": ["go"],
      "rootPatterns": ["go.mod"],
      "settings": {
        "completeUnimported": true
      }
    },
    "kotlin": {
      "command": "/Users/nisidabay/.vim/lsp/server/bin/kotlin-language-server",
      "args": ["start"],
      "filetypes": ["kotlin"]
    },
    "python": {
      "command": "pyright-langserver",
      "args": ["--stdio"],
      "filetypes": ["python"],
      "settings": {
        "python.analysis.typeCheckingMode": "basic",
        "python.analysis.diagnosticMode": "workspace",
        "python.analysis.useLibraryCodeForTypes": true,
        "python.analysis.disableLanguageServices": false,
        "python.analysis.disableOrganizeImports": false,
        "python.analysis.reportMissingImports": true,
        "python.analysis.reportMissingTypeStubs": false
      }
    }
  },
  "clangd": {
    "path": "clangd",
    "arguments": [
      "--background-index",
      "--clang-tidy",
      "--header-insertion=iwyu",
      "--completion-style=detailed",
      "--function-arg-placeholders"
    ],
    "filetypes": ["c", "cpp", "objc", "objcpp"]
  },
  "sh": {
    "enable": true,
    "filetypes": ["sh"],
    "highlightParsingErrors": true,
    "format": {
      "enable": true,
      "provider": "shfmt"
    }
  },
  "shfmt": {
    "executablePath": "shfmt",
    "args": ["-i", "2", "-ci", "-sr"]
  },
  "coc.preferences.extensionUpdateCheck": "daily"
}
